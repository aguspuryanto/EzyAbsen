rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Functions
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Users Collection
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt', 'updatedAt']) 
        && data.size() == 6
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 100
        && data.role in ['employee', 'admin']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /users/{userId} {
      // Create is allowed on initial sign-up, but user can only set 'employee' role unless they have a backdoor admin email setup (simplified here)
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid 
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time
                    && incoming().role == 'employee'; 
                    
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      
      allow update: if isSignedIn() && isValidId(userId) && (
        isAdmin() || 
        (userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']) 
         && incoming().updatedAt == request.time 
         && incoming().name is string && incoming().name.size() <= 100)
      );
      allow delete: if false; // Users shouldn't be deleted easily
    }

    // Attendances Collection
    function isValidCheckInLocation(loc) {
      return loc.keys().hasAll(['lat', 'lng']) && loc.size() == 2 && loc.lat is number && loc.lng is number;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['userId', 'date', 'checkInTime', 'checkInLocation', 'status', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.date is string && data.date.size() == 10 // YYYY-MM-DD
        && data.checkInTime is timestamp
        && isValidCheckInLocation(data.checkInLocation)
        && data.status in ['present', 'late']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        // Optional fields (for checkout)
        && (!('checkOutTime' in data) || data.checkOutTime is timestamp)
        && (!('checkOutLocation' in data) || isValidCheckInLocation(data.checkOutLocation))
        && (!('checkInPhotoUrl' in data) || (data.checkInPhotoUrl is string && data.checkInPhotoUrl.size() <= 1000))
        && (!('checkOutPhotoUrl' in data) || (data.checkOutPhotoUrl is string && data.checkOutPhotoUrl.size() <= 1000));
    }

    match /attendances/{attendanceId} {
      allow create: if isSignedIn() && isValidId(attendanceId)
                    && isValidAttendance(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if isSignedIn() && isValidId(attendanceId) && (
        isAdmin() ||
        (existing().userId == request.auth.uid 
         && incoming().diff(existing()).affectedKeys().hasOnly(['checkOutTime', 'checkOutLocation', 'checkOutPhotoUrl', 'updatedAt'])
         && incoming().updatedAt == request.time
         // basic validation of the checkout fields inline assuming valid types
        )
      );
    }

    // LeaveRequests Collection
    function isValidLeaveRequest(data) {
      return data.keys().hasAll(['userId', 'type', 'startDate', 'endDate', 'reason', 'status', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.type in ['sick', 'annual', 'permit']
        && data.startDate is string && data.startDate.size() == 10
        && data.endDate is string && data.endDate.size() == 10
        && data.reason is string && data.reason.size() <= 1000
        && data.status in ['pending', 'approved', 'rejected']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (!('attachmentUrl' in data) || (data.attachmentUrl is string && data.attachmentUrl.size() <= 1000));
    }

    match /leaveRequests/{requestId} {
      allow create: if isSignedIn() && isValidId(requestId)
                    && isValidLeaveRequest(incoming())
                    && incoming().status == 'pending'
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if isSignedIn() && isValidId(requestId) && (
        isAdmin() || 
        (existing().userId == request.auth.uid 
         && existing().status == 'pending' // Only allow updates if still pending
         && incoming().diff(existing()).affectedKeys().hasOnly(['type', 'startDate', 'endDate', 'reason', 'attachmentUrl', 'updatedAt'])
         && incoming().updatedAt == request.time
        )
      );
      allow delete: if isSignedIn() && isValidId(requestId) && existing().userId == request.auth.uid && existing().status == 'pending';
    }
  }
}
