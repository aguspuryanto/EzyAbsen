{
  "entities": {
    "User": {
      "title": "User",
      "description": "Employee or administrator profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt", "updatedAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record for an employee",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "checkInTime": { "type": "string", "format": "date-time" },
        "checkInLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "checkInPhotoUrl": { "type": "string" },
        "checkOutTime": { "type": "string", "format": "date-time" },
        "checkOutLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "checkOutPhotoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "late"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "checkInTime", "checkInLocation", "status", "createdAt", "updatedAt"]
    },
    "LeaveRequest": {
      "title": "LeaveRequest",
      "description": "Request for leave/permit",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["sick", "annual", "permit"] },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "attachmentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "startDate", "endDate", "reason", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles"
    },
    "/attendances/{attendanceId}": {
      "schema": { "$ref": "#/entities/Attendance" },
      "description": "Employee attendance records"
    },
    "/leaveRequests/{requestId}": {
      "schema": { "$ref": "#/entities/LeaveRequest" },
      "description": "Employee leave requests"
    }
  }
}
